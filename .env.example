# ============================================
# 造价智能助手 - 环境变量配置模板
# 使用方法：复制此文件为 .env，填写真实配置
# ============================================

# OpenAI 兼容 API 地址（以 /v1 结尾，不要带末尾斜杠）
# 示例：
#   OpenAI:      https://api.openai.com/v1
#   DeepSeek:    https://api.deepseek.com/v1
#   通义千问:     https://dashscope.aliyuncs.com/compatible-mode/v1
#   文心一言:     https://aip.baidubce.com/rpc/2.0/ai_custom/v1/wenxinworkshop
#   Kimi:        https://api.moonshot.cn/v1
#   Ollama:      http://localhost:11434/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# API Key（从对应平台获取）
OPENAI_API_KEY=sk-your-api-key-here

# 模型名称
# 示例：gpt-4o-mini, deepseek-chat, qwen-plus, ernie-speed, moonshot-v1-8k, llama3.1
OPENAI_MODEL=gpt-4o-mini

# 系统提示词（可选，不填则使用默认造价工程师人设）
SYSTEM_PROMPT=你是一位资深的工程造价专家，精通工程量计算、定额计价、清单编制、造价审核、招投标管理等专业知识。请用专业、准确、清晰的语言回答用户的问题。

# 服务端口（可选，默认 8080）
PORT=8080
